{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "refill_due",
  "description": "Refill variklis prognozuoja kad klientas artejasi prie maisto pabaigos (M11).",
  "schema_version": 1,
  "type": "object",
  "required": ["schema_version", "event_name", "event_id", "emitted_at", "email", "payload"],
  "properties": {
    "schema_version": {"const": 1},
    "event_name": {"const": "refill_due"},
    "event_id": {"type": "string"},
    "emitted_at": {"type": "string", "format": "date-time"},
    "email": {"type": "string", "format": "email"},
    "customer_id": {"type": "integer"},
    "payload": {
      "type": "object",
      "required": ["pet_id", "product_id", "predicted_empty_date", "confidence"],
      "properties": {
        "pet_id": {"type": "integer"},
        "product_id": {"type": "integer"},
        "product_name": {"type": "string"},
        "predicted_empty_date": {"type": "string", "format": "date"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "last_order_id": {"type": "integer"},
        "days_since_last_order": {"type": "integer"}
      }
    }
  }
}

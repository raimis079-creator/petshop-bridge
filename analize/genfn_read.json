{
    "220": "//   update_option('petshop_avpn_counter', 101)",
    "221": "//   update_option('petshop_iapv_counter', 101)",
    "222": "// ===============================================================",
    "223": "function petshop_get_avpn_number( $order_id ) {",
    "224": "    $order    = wc_get_order( $order_id );",
    "225": "    $existing = $order ? $order->get_meta( '_petshop_avpn_number' ) : '';",
    "226": "    if ( $existing ) return $existing;",
    "227": "    $counter = (int) get_option( 'petshop_avpn_counter', 101 );",
    "228": "    $number  = 'AVPN' . str_pad( $counter, 6, '0', STR_PAD_LEFT );",
    "229": "    update_option( 'petshop_avpn_counter', $counter + 1 );",
    "230": "    if ( $order ) {",
    "231": "        $order->update_meta_data( '_petshop_avpn_number', $number );",
    "232": "        $order->save();",
    "233": "    }",
    "234": "    return $number;",
    "235": "}",
    "236": "",
    "237": "function petshop_get_iapv_number( $order_id ) {",
    "238": "    $order    = wc_get_order( $order_id );",
    "239": "    $existing = $order ? $order->get_meta( '_petshop_iapv_number' ) : '';",
    "240": "    if ( $existing ) return $existing;",
    "241": "    $counter = (int) get_option( 'petshop_iapv_counter', 101 );",
    "242": "    $number  = 'IAPV' . str_pad( $counter, 6, '0', STR_PAD_LEFT );",
    "243": "    update_option( 'petshop_iapv_counter', $counter + 1 );",
    "244": "    if ( $order ) {",
    "245": "        $order->update_meta_data( '_petshop_iapv_number', $number );",
    "246": "        $order->save();",
    "247": "    }",
    "248": "    return $number;",
    "249": "}",
    "250": "",
    "251": "function petshop_get_invoice_document_type( $order ) {",
    "252": "    if ( ! $order instanceof WC_Order ) return 'invoice';",
    "253": "    $payment_method   = $order->get_payment_method();",
    "254": "    $is_bank_transfer = ( $payment_method === 'bacs' );",
    "255": "    if ( $is_bank_transfer && in_array( $order->get_status(), array( 'pending', 'on-hold' ), true ) ) {",
    "256": "        return 'proforma';",
    "257": "    }",
    "258": "    return 'invoice';",
    "259": "}",
    "260": "",
    "261": "function petshop_get_invoice_title( $order ) {",
    "262": "    $type     = petshop_get_invoice_document_type( $order );",
    "263": "    $order_id = $order->get_id();",
    "264": "    if ( $type === 'proforma' ) {",
    "265": "        return array(",
    "266": "            'title'  => 'Išankstinisė sąskaita',",
    "267": "            'number' => petshop_get_iapv_number( $order_id ),",
    "268": "        );",
    "269": "    }",
    "270": "    return array(",
    "271": "        'title'  => 'PVM sąskaita faktūra',",
    "272": "        'number' => petshop_get_avpn_number( $order_id ),",
    "273": "    );",
    "274": "}",
    "275": "",
    "276": "// ===============================================================",
    "277": "// PDF saskaitos generavimas",
    "278": "// ===============================================================",
    "279": "function petshop_generate_invoice_pdf( $order_id ) {",
    "280": "    $wc_order = wc_get_order( $order_id );",
    "281": "    if ( ! $wc_order ) return false;",
    "282": "",
    "283": "    $countries      = WC()->countries ? WC()->countries->get_countries() : array();",
    "284": "    $b_country      = $wc_order->get_billing_country();",
    "285": "    $b_country_name = isset( $countries[ $b_country ] ) ? $countries[ $b_country ] : $b_country;",
    "286": "",
    "287": "    $skip_states = array( 'pasirinkite rajona', 'select a region', 'select an option' );",
    "288": "    $b_state     = $wc_order->get_billing_state();",
    "289": "    $b_state_val = ( $b_state && ! in_array( mb_strtolower( $b_state ), $skip_states ) ) ? $b_state : '';",
    "290": "",
    "291": "    $city_post = trim( $wc_order->get_billing_city() . ( $wc_order->get_billing_postcode() ? ', ' . $wc_order->get_billing_postcode() : '' ) );",
    "292": "",
    "293": "    $billing_lines = array_values( array_filter( array(",
    "294": "        $wc_order->get_billing_address_1(),",
    "295": "        $wc_order->get_billing_address_2(),",
    "296": "        $city_post,",
    "297": "        $b_state_val,",
    "298": "        $b_country_name,",
    "299": "    ) ) );",
    "300": "",
    "301": "    $order = array(",
    "302": "        'id'            => $order_id,",
    "303": "        'orderNumber'   => $wc_order->get_order_number(),",
    "304": "        'documentDate'  => date_i18n( 'Y-m-d' ),",
    "305": "        'date'          => $wc_order->get_date_created()",
    "306": "                            ? $wc_order->get_date_created()->format( 'Y-m-d' )",
    "307": "                            : date( 'Y-m-d' ),",
    "308": "        'paymentMethod' => $wc_order->get_payment_method_title(),",
    "309": "        'billing'       => array(",
    "310": "            'name'    => trim( $wc_order->get_billing_first_name() . ' ' . $wc_order->get_billing_last_name() ),",
    "311": "            'address' => $billing_lines,",
    "312": "            'phone'   => $wc_order->get_billing_phone(),",
    "313": "            'email'   => $wc_order->get_billing_email(),",
    "314": "        ),",
    "315": "        'shipping'      => array( 'name' => '', 'address' => array() ),",
    "316": "    );",
    "317": "",
    "318": "    $logo_url  = '';",
    "319": "    $logo_path = '';",
    "320": "    $flatsome_logo_id = get_theme_mod( 'site_logo' );",
    "321": "    if ( $flatsome_logo_id ) {",
    "322": "        $logo_url  = wp_get_attachment_image_url( $flatsome_logo_id, 'full' );",
    "323": "        $logo_path = get_attached_file( $flatsome_logo_id );",
    "324": "    }",
    "325": "",
    "326": "    $shop     = array( 'logo' => $logo_url, 'logo_path' => $logo_path, 'name' => get_bloginfo( 'name' ) );",
    "327": "    $settings = array( 'displayPriceInProductDetailsTable' => true );",
    "328": "    $document = array();",
    "329": "    $template = 'invoice';",
    "330": "    $type     = 'pdf';",
    "331": "    $items    = array();",
    "332": "    $totals   = array();",
    "333": "",
    "334": "    $template_file = get_stylesheet_directory() . '/woocommerce-delivery-notes/base.php';",
    "335": "    if ( ! file_exists( $template_file ) ) return false;",
    "336": "",
    "337": "    ob_start();",
    "338": "    include $template_file;",
    "339": "    $body_html = ob_get_clean();",
    "340": "",
    "341": "    $full_html = '<!DOCTYPE html><html><head><meta charset=\"UTF-8\"><style>@page{size:A4;margin:12mm 14mm;}body{margin:0;padding:0;}</style></head><body>' . $body_html . '</body></html>';",
    "342": "",
    "343": "    if ( ! class_exists( 'Dompdf\\Dompdf' ) ) return false;",
    "344": "",
    "345": "    $upload_dir = wp_upload_dir();",
    "346": "    $pdf_dir    = trailingslashit( $upload_dir['basedir'] ) . 'wcdn/invoice/';",
    "347": "    wp_mkdir_p( $pdf_dir );",
    "348": "    $pdf_file = $pdf_dir . 'invoice-' . $order_id . '-' . time() . '.pdf';",
    "349": "",
    "350": "    try {",
    "351": "        $options = new \\Dompdf\\Options();",
    "352": "        $options->set( 'isRemoteEnabled', true );",
    "353": "        $options->set( 'isHtml5ParserEnabled', true );",
    "354": "        $options->set( 'isFontSubsettingEnabled', true );",
    "355": "        $options->set( 'chroot', array( realpath( ABSPATH ), realpath( $upload_dir['basedir'] ) ) );",
    "356": "        $dompdf = new \\Dompdf\\Dompdf( $options );",
    "357": "        $dompdf->loadHtml( $full_html, 'UTF-8' );",
    "358": "        $dompdf->setPaper( array( 0, 0, 595.28, 841.89 ), 'portrait' );",
    "359": "        $dompdf->render();",
    "360": "        file_put_contents( $pdf_file, $dompdf->output() );",
    "361": "        return file_exists( $pdf_file ) ? $pdf_file : false;",
    "362": "    } catch ( \\Throwable $e ) {",
    "363": "        return false;",
    "364": "    }",
    "365": "}",
    "366": "",
    "367": "// ===============================================================",
    "368": "// Laiskas #1 - Uzsakymas gautas",
    "369": "// ===============================================================",
    "370": "add_action( 'woocommerce_checkout_order_created', function( $order ) {",
    "371": "    $doc_type = petshop_get_invoice_document_type( $order );",
    "372": "    $order->update_meta_data( '_petshop_invoice_document_type', $doc_type );",
    "373": "    try {",
    "374": "        $order_id = $order->get_id();",
    "375": "        $order->save();",
    "376": "        $pdf_file = petshop_generate_invoice_pdf( $order_id );",
    "377": "        if ( $pdf_file && file_exists( $pdf_file ) ) {",
    "378": "            $order->update_meta_data( '_petshop_order_pdf', $pdf_file );",
    "379": "            $order->save();",
    "380": "        }",
    "381": "    } catch ( \\Throwable $e ) {}",
    "382": "    wp_schedule_single_event( time() + 5, 'petshop_send_order_received_email', array( $order->get_id() ) );",
    "383": "}, 20 );",
    "384": "",
    "385": "add_action( 'petshop_send_order_received_email', function( $order_id ) {",
    "386": "    $order = wc_get_order( $order_id );",
    "387": "    if ( ! $order ) return;",
    "388": "",
    "389": "    $payment_method_id = $order->get_payment_method();",
    "390": "    $is_bank           = ( $payment_method_id === 'bacs' );",
    "391": "",
    "392": "    $items_html  = '<h2 style=\"font-size:16px;margin:16px 0 8px;\">Jūsų užsakymas:</h2>';",
    "393": "    $items_html .= '<table cellpadding=\"8\" style=\"width:100%;border-collapse:collapse;font-size:14px;\">';",
    "394": "    $items_html .= '<tr style=\"background:#f4f4f2;\"><th style=\"text-align:left;border-bottom:2px solid #ddd;\">Prekė</th><th style=\"text-align:center;border-bottom:2px solid #ddd;\">Kiekis</th><th style=\"text-align:right;border-bottom:2px solid #ddd;\">Suma</th></tr>';",
    "395": "    foreach ( $order->get_items() as $item ) {",
    "396": "        $total       = $item->get_total() + $item->get_total_tax();",
    "397": "        $items_html .= '<tr style=\"border-bottom:1px solid #eee;\">';",
    "398": "        $items_html .= '<td>' . esc_html( $item->get_name() ) . '</td>';",
    "399": "        $items_html .= '<td style=\"text-align:center;\">' . $item->get_quantity() . '</td>';",
    "400": "        $items_html .= '<td style=\"text-align:right;\">' . wc_price( $total ) . '</td>';",
    "401": "        $items_html .= '</tr>';",
    "402": "    }",
    "403": "    $items_html .= '</table>';",
    "404": "    $items_html .= '<table style=\"width:100%;margin-top:8px;font-size:14px;\">';",
    "405": "    $items_html .= '<tr><td style=\"padding:4px 8px;\">Pristatymas:</td><td style=\"text-align:right;padding:4px 8px;\">' . wc_price( $order->get_shipping_total() + $order->get_shipping_tax() ) . '</td></tr>';",
    "406": "    $items_html .= '<tr><td style=\"padding:4px 8px;\">PVM:</td><td style=\"text-align:right;padding:4px 8px;\">' . wc_price( $order->get_total_tax() ) . '</td></tr>';",
    "407": "    $items_html .= '<tr><td style=\"padding:4px 8px;font-weight:bold;\">Viso:</td><td style=\"text-align:right;padding:4px 8px;font-weight:bold;\">' . wc_price( $order->get_total() ) . '</td></tr>';",
    "408": "    $items_html .= '</table>';",
    "409": "",
    "410": "    $bank_html = '';",
    "411": "    if ( $is_bank ) {",
    "412": "        $bank_html = '<div style=\"background:#f9f9f9;border:1px solid #e0e0e0;padding:16px;margin:16px 0;font-size:14px;\">'",
    "413": "            . '<p style=\"font-weight:bold;margin-bottom:8px;\">Mokėjimo rekvizitai:</p>'",
    "414": "            . '<table style=\"width:100%;\">'",
    "415": "            . '<tr><td style=\"padding:3px 0;color:#666;width:40%;\">Gavėjas:</td><td><strong>UAB Avesa</strong></td></tr>'",
    "416": "            . '<tr><td style=\"padding:3px 0;color:#666;\">Bankas:</td><td>AB Swedbank</td></tr>'",
    "417": "            . '<tr><td style=\"padding:3px 0;color:#666;\">Šąskaita:</td><td><strong>LT127300010124940593</strong></td></tr>'",
    "418": "            . '<tr><td style=\"padding:3px 0;color:#666;\">Suma:</td><td><strong>' . wc_price( $order->get_total() ) . '</strong></td></tr>'",
    "419": "            . '<tr><td style=\"padding:3px 0;color:#666;\">Mokėjimo paskirtis:</td><td><strong>Užsakymas Nr. ' . $order->get_order_number() . '</strong></td></tr>'",
    "420": "            . '</table></div>';",
    "421": "    }",
    "422": "",
    "423": "    $pdf_attachment = array();",
    "424": "    try {",
    "425": "        $petshop_pdf = $order->get_meta( '_petshop_order_pdf' );",
    "426": "        if ( $petshop_pdf && file_exists( $petshop_pdf ) ) {",
    "427": "            $pdf_attachment[] = $petshop_pdf;",
    "428": "        }",
    "429": "        if ( empty( $pdf_attachment ) ) {",
    "430": "            $pdf_file = petshop_generate_invoice_pdf( $order_id );",
    "431": "            if ( $pdf_file && file_exists( $pdf_file ) ) {",
    "432": "                $pdf_attachment[] = $pdf_file;",
    "433": "            }",
    "434": "        }",
    "435": "    } catch ( \\Throwable $e ) {}",
    "436": "",
    "437": "    $to      = $order->get_billing_email();",
    "438": "    $subject = 'Jūsų užsakymas Nr. ' . $order->get_order_number() . ' gautas - Petshop.lt';",
    "439": "    $heading = 'Užsakymas gautas, ačiū!';",
    "440": "    $intro   = $is_bank",
    "441": "        ? 'Gavę apmokėjimą, pradėsime vykdyti užsakymą ir informuosime Jus atskiru pranešimu.'",
    "442": "        : 'Kai tik gausime apmokėjimą, pradėsime vykdyti užsakymą ir informuosime Jus atskiru pranešimu.';",
    "443": "",
    "444": "    $message = '<p>Laba diena, ' . esc_html( $order->get_billing_first_name() ) . ',</p>'",
    "445": "        . '<p>Jūsų užsakymas Nr. ' . $order->get_order_number() . ' gautas. Ačiū! :)</p>'",
    "446": "        . $items_html",
    "447": "        . $bank_html",
    "448": "        . '<br><p>' . $intro . '</p>'",
    "449": "        . '<br><p>Gražios dienų,<br>Petshop.lt komanda<br>+370 681 87787<br>terra@petshop.lt</p>';",
    "450": "",
    "451": "    $mailer  = WC()->mailer();",
    "452": "    $wrapped = $mailer->wrap_message( $heading, $message );",
    "453": "    if ( ! empty( $pdf_attachment ) ) {",
    "454": "        $mailer->send( $to, $subject, $wrapped, '', $pdf_attachment );",
    "455": "    } else {",
    "456": "        $mailer->send( $to, $subject, $wrapped );",
    "457": "    }",
    "458": "} );",
    "459": "",
    "460": "// ===============================================================",
    "461": "// Statuso pakeitimo hook",
    "462": "// ===============================================================",
    "463": "add_action( 'woocommerce_order_status_changed', function( $order_id, $old_status, $new_status, $order ) {",
    "464": "    if ( ! $order instanceof WC_Order ) {",
    "465": "        $order = wc_get_order( $order_id );",
    "466": "    }",
    "467": "    if ( ! $order ) return;",
    "468": "    $doc_type = petshop_get_invoice_document_type( $order );",
    "469": "    $order->update_meta_data( '_petshop_invoice_document_type', $doc_type );",
    "470": "    $order->delete_meta_data( '_wcdn_invoice_pdf' );",
    "471": "    $order->delete_meta_data( '_wcdn_invoice_pdf_token' );",
    "472": "    $order->save();",
    "473": "}, 1, 4 );",
    "474": "",
    "475": "// ==============================================================="
}
        "485": "             strpos( $combined, 'lp_express' ) !== false ||",
        "486": "             strpos( $combined, 'lp express' ) !== false ) return 'lpexpress';",
        "487": "        break;",
        "488": "    }",
        "489": "    return 'unknown';",
        "490": "}",

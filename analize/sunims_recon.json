    "snippet_332": {
        "name": "Petshop Filtru Kontekstas v19 [VISADA AKTYVUS]",
        "len": 7855,
        "hits": [
            "7: * Parenka YITH preset pagal kategorija:",
            "8: *   - skanestu kategorijos    -> skanestu-filtras",
            "9: *   - vitaminu/papildu kat.   -> vitaminu-filtras",
            "10: *   - antkakliu/pavadeliu kat -> antkakliu-filtras",
            "11: *   - dubeneliu kat           -> dubeneliu-filtras",
            "12: *   - guoliu/transp/narvu kat -> guoliu-transporto-filtras  (NAUJA v5)",
            "13: *   - zaislu kategorijos      -> zaislu-filtras              (NAUJA v6)",
            "14: *   - kraiku kategorija        -> kraiku-filtras              (NAUJA v7)",
            "15: *   - apranga sunims           -> apranga-filtras             (NAUJA v8)",
            "16: *   - draskykles katems        -> draskykliu-filtras          (NAUJA v9)",
            "17: *   - sampunai sunims          -> sampunu-filtras             (NAUJA v10)",
            "18: *   - sukos/sepeciai/zirkles   -> suku-filtras                (NAUJA v11)",
            "19: *   - higienos priemones sunims-> suku-filtras (pa_tipas reuse)  (NAUJA v12)",
            "20: *   - display=subcategories kat-> filtras SLEPIAMAS (return false) (NAUJA v13)",
            "21: *   - grauzikams tevine (misri) -> tevine-filtras (tik brand)    (NAUJA v14)",
            "22: *   - pasaras grauzikams        -> grauziko-rusis-filtras       (NAUJA v15)",
            "23: *   - lesalas pauksciams        -> paukscio-rusis-filtras       (NAUJA v16)",
            "24: *   - akvariumo zuvu maistas    -> akvariumo-zuvu-filtras       (NAUJA v17)",
            "25: *   - tualetai/kraikai/semtuv.  -> tualetu-filtras (dedikuotas, Tipas+Brand)     (NAUJA v18/v19)",
            "26: *   - maisto kategorijos      -> maisto-filtras",
            "29: * Veikia per widget_display_callback: kai renderinamas YITH preset",
            "30: * widget, pakeicia preset slug pagal dabartine kategorija.",
            "32: * Tvarko maista + skanestus + papildus. Aksesuarai / dp misri -",
            "33: * nepaliesta, kol joms bus sukurti atskiri preset'ai.",
            "35: * Slug'ai: maisto-filtras, skanestu-filtras, vitaminu-filtras, antkakliu-filtras, dubeneliu-filtras, guoliu-transporto-filtras, zaislu-filtras, kraiku-filtras,",
            "42: * Nustato, kuris preset slug tinka dabartinei kategorijai.",
            "45: function petshop_filter_preset_for_current() {",
            "47: if ( ! is_product_category() && ! is_tax('product_cat') ) {",
            "51: if ( ! $term || empty($term->slug) ) {",
            "54: $slug = strtolower( $term->slug );",
            "56: // TEVINE GRAUZIKAMS (misri kategorija: maistas+aksesuarai) -> tik brand (v14)",
            "58: return 'tevine-filtras';",
            "61: // PASARAS GRAUZIKAMS -> Grauziko rusis filtras (v15)",
            "63: return 'grauziko-rusis-filtras';",
            "66: // LESALAS PAUKSCIAMS -> Paukscio rusis filtras (v16)",
            "68: return 'paukscio-rusis-filtras';",
            "71: // AKVARIUMO ZUVU MAISTAS -> Zuvies rusis + Pasaro forma filtras (v17)",
            "72: if ( strpos( $slug, 'akvariumo-zuvyciu-maistas' ) !== false ) {",
            "73: return 'akvariumo-zuvu-filtras';",
            "80: return 'skanestu-filtras';",
            "84: // VITAMINAI / PAPILDAI (NAUJA v2 - pries maista, kad nesusikirstu)",
            "85: // papildu slug'ai: vitaminai-ir-papildai-sunims / -katems",
            "89: return 'vitaminu-filtras';",
            "93: // ANTKAKLIAI / PAVADELIAI (NAUJA v3 - pries maista)",
            "94: // slug'ai: antkakliai-pavadeliai-sunims",
            "98: return 'antkakliu-filtras';",
            "103: // slug: dubeneliai-sunims",
            "107: return 'dubeneliu-filtras';",
            "112: // slug'ai: guoliai-boksai-sunims, guoliai-katems, transportavimo-dezes-*,",
            "118: return 'guoliu-transporto-filtras';"
        ]
    },
